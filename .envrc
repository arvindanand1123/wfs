# Loaded automatically by direnv when you cd into this directory.
# Run `direnv allow` once to authorize it.

# Create the venv on first entry if it doesn't exist yet.
if [[ ! -d .venv ]]; then
    echo "wfs: creating .venv ..."
    if command -v uv >/dev/null 2>&1; then
        uv venv .venv
    else
        python3 -m venv .venv
    fi
fi

# Activate the venv for this shell session.
source .venv/bin/activate

# Project env vars (override these locally; never commit secrets).
# Copy .env.example -> .env and fill in real values.
if [[ -f .env ]]; then
    dotenv .env
fi

export PYTHONPATH="${PWD}/src:${PYTHONPATH}"
