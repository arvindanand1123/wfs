# Copy to `.env` and fill in real values. `.env` is gitignored.
# These configure the upstream S3-compatible backend (R2, MinIO, AWS, etc.).

S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=

# App settings
LOG_LEVEL=info
